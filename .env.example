# === BharatAI Platform Environment Variables ===

# FastAPI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://bharatai:bharatai_dev@localhost:5432/bharatai
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# === Multi-Provider LLM Configuration ===
# Default LLM (used when no app-specific config exists)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2:3b-instruct-q4_0
# Fallback chain: comma-separated "provider:model" pairs
# DEFAULT_LLM_FALLBACK=groq:llama-3.3-70b-versatile,gemini:gemini-2.0-flash

# Ollama (Local — always available if running)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2:3b-instruct-q4_0
VRAM_BUDGET_MB=7000

# Groq (Free tier: 30 req/min)
# GROQ_API_KEY=gsk_your_key_here

# Google Gemini (Free tier: 15 req/min for flash)
# GEMINI_API_KEY=your_key_here

# Anthropic Claude (Paid)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Sarvam AI (Hindi-optimized)
# SARVAM_API_KEY=your_key_here

# OpenAI Compatible (vLLM, LM Studio, LocalAI, text-generation-inference)
# OPENAI_API_BASE=http://localhost:8080/v1
# OPENAI_API_KEY=dummy

# STT (faster-whisper / IndicWhisper)
# Use "ai4bharat/indicwhisper-medium" for Indian languages (default)
# Use "medium" or "large-v2" for generic Whisper
WHISPER_MODEL_SIZE=ai4bharat/indicwhisper-medium
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# TTS
TTS_ENGINE=gtts

# Auth — API keys per app (MVP: static keys)
ASHA_HEALTH_API_KEY=dev-asha-key-001
LAWYER_AI_API_KEY=dev-lawyer-key-001

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Voice pipeline
MAX_AUDIO_SIZE_MB=10
MAX_AUDIO_DURATION_SECONDS=60
STT_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
